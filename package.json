{
  "name": "@glamsystems/ix-mapper",
  "version": "0.2.3",
  "description": "Map Solana program instructions to GLAM integration instructions",
  "main": "./index.cjs",
  "module": "./index.esm.js",
  "types": "./index.cjs.d.ts",
  "homepage": "https://www.glam.systems",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glamsystems/ix-mapper-ts.git"
  },
  "keywords": [
    "glam",
    "solana",
    "defi"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "files": [
    "README.md",
    "LICENSE",
    "index.cjs",
    "index.esm.js",
    "index.cjs.d.ts",
    "index.esm.d.ts",
    "src/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.2",
    "typescript": "^5.8.3"
  }
}
